<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mini Gry"
        android:textSize="42sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wybierz gre:"
        android:textSize="18sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnKolkoKrzyzyk"
        android:layout_width="260dp"
        android:layout_height="70dp"
        android:text="Kolko i Krzyzyk"
        android:textSize="18sp"
        android:backgroundTint="#e94560"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnPapierKamien"
        android:layout_width="260dp"
        android:layout_height="70dp"
        android:text="Papier Kamien Nozyce"
        android:textSize="18sp"
        android:backgroundTint="#0f3460"/>

</LinearLayout>