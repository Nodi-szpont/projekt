<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Papier Kamien Nozyce"
        android:textSize="26sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvWynikGracz"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ty: ?"
        android:textSize="32sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvWynikKomputer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Komputer: ?"
        android:textSize="32sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvRezultat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wybierz cos!"
        android:textSize="22sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvPunkty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wynik: 0 - 0"
        android:textSize="18sp"
        android:textColor="#aaaaaa"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnKamien"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="Kamien"
            android:textSize="14sp"
            android:backgroundTint="#16213e"
            android:layout_margin="8dp"/>

        <Button
            android:id="@+id/btnPapier"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="Papier"
            android:textSize="14sp"
            android:backgroundTint="#16213e"
            android:layout_margin="8dp"/>

        <Button
            android:id="@+id/btnNozyce"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="Nozyce"
            android:textSize="14sp"
            android:backgroundTint="#16213e"
            android:layout_margin="8dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnWrocPKN"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="Menu"
        android:backgroundTint="#0f3460"
        android:layout_marginTop="24dp"/>

</LinearLayout>